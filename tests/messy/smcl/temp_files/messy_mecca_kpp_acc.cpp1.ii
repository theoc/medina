    cudaMalloc ((void **) &d_absTol_s , sizeof(float)*73);
    cudaMalloc ((void **) &d_relTol_s , sizeof(float)*73);


    cudaMalloc ((void **) &temp_gpu_s , sizeof(float)*VL_GLO);
    cudaMalloc ((void **) &press_gpu_s , sizeof(float)*VL_GLO);
    cudaMalloc ((void **) &cair_gpu_s , sizeof(float)*VL_GLO);


    cudaMalloc ((void **) &d_jac0_s, sizeof(float)*VL_GLO*455);
    cudaMalloc ((void **) &d_Ghimj_s, sizeof(float)*VL_GLO*455);
    cudaMalloc ((void **) &d_varNew_s, sizeof(float)*VL_GLO*73);
